  "generatedAt": "2024-01-01T00:00:00.000Z",
  "summary": {
    "totalPages": 3,
    "totalIssues": 10,
    "avgScore": 83
  },
  "topIssues": [...],
  "pagesByScore": [
    { "route": "/sobre", "score": 70 },
    { "route": "/contato", "score": 85 },
    { "route": "/", "score": 95 }
  ],
  "pages": [...]
}
```

